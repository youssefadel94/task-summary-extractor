{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "analysis-compiled",
  "title": "Compiled Analysis Output",
  "description": "JSON Schema for the final compiled analysis. Same structure as segment but with relaxed requirements since compilation merges multiple segments. Uses additionalProperties:true to allow extra fields.",
  "type": "object",
  "additionalProperties": true,
  "required": ["summary"],
  "properties": {
    "tickets": {
      "$comment": "Compiled tickets may be deduplicated/merged across segments",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["ticket_id", "title"],
        "properties": {
          "ticket_id": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["open", "closed", "in_progress", "blocked", "pending_review", "complete_pending_deployment"]
          },
          "assignee": { "type": ["string", "null"] },
          "reviewer": { "type": ["string", "null"] },
          "documented_state": {
            "type": ["object", "null"],
            "additionalProperties": true,
            "properties": {
              "source": { "type": ["string", "null"] },
              "plan_status": { "type": "string" },
              "checklist_progress": { "type": "string" },
              "sub_tickets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "id": { "type": "string" },
                    "title": { "type": "string" },
                    "documented_status": { "type": "string" }
                  }
                }
              },
              "open_blockers": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "discussed_state": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "summary": { "type": "string" },
              "discrepancies": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "video_segments": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "start_time": { "type": ["string", "null"] },
                "end_time": { "type": ["string", "null"] },
                "description": { "type": "string" }
              }
            }
          },
          "comments": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "timestamp": { "type": ["string", "null"] },
                "speaker": { "type": "string" },
                "text": { "type": "string" }
              }
            }
          },
          "code_changes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["bug_fix", "feature", "refactor", "optimization", "cleanup", "upgrade", "integration", "process_change", "policy_update", "design_revision", "content_update"]
                },
                "file_path": { "type": ["string", "null"] },
                "description": { "type": "string" },
                "details": { "type": "string" },
                "priority": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "critical"]
                },
                "referenced_at": { "type": ["string", "null"] }
              }
            }
          },
          "confidence": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"]
          },
          "confidence_reason": { "type": "string" }
        }
      }
    },
    "change_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "what"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "where": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "file_path": { "type": ["string", "null"] },
              "module": { "type": "string" },
              "component": { "type": "string" }
            }
          },
          "code_map_match": { "type": ["string", "null"] },
          "what": { "type": "string" },
          "how": { "type": "string" },
          "why": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["bug_fix", "feature", "refactor", "optimization", "cleanup", "upgrade", "integration", "configuration", "process_change", "policy_update", "contract_revision", "design_change", "content_update", "documentation"]
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "status": {
            "type": "string",
            "enum": ["actionable", "pending_decision", "blocked", "completed"]
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "blocked_by": { "type": ["string", "null"] },
          "related_tickets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "referenced_at": { "type": ["string", "null"] },
          "assigned_to": { "type": ["string", "null"] },
          "confidence": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"]
          },
          "confidence_reason": { "type": "string" }
        }
      }
    },
    "file_references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "file_name": { "type": "string" },
          "resolved_path": { "type": ["string", "null"] },
          "file_type": {
            "type": "string",
            "enum": [
              "source_code", "configuration", "documentation", "database", "enum", "dto",
              "api_endpoint", "ui_component", "script", "diagram", "translation", "stylesheet",
              "contract", "report", "spreadsheet", "presentation", "mockup", "design_asset",
              "policy", "form", "email", "crm_entry"
            ]
          },
          "role": {
            "type": "string",
            "enum": [
              "needs_modification", "reference_only", "source_of_truth", "to_be_created",
              "to_be_deleted", "to_be_reviewed", "already_modified", "needs_approval"
            ]
          },
          "mentioned_in_tickets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "mentioned_in_changes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "context_doc_match": { "type": ["string", "null"] },
          "notes": { "type": "string" }
        }
      }
    },
    "action_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "assigned_to": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "done", "blocked", "deferred"]
          },
          "checklist_match": { "type": ["string", "null"] },
          "deadline": { "type": ["string", "null"] },
          "depends_on": { "type": ["string", "null"] },
          "related_tickets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_changes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "referenced_at": { "type": ["string", "null"] },
          "confidence": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"]
          },
          "confidence_reason": { "type": "string" }
        }
      }
    },
    "scope_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["added", "removed", "deferred", "approach_changed", "ownership_changed", "requirements_changed"]
          },
          "related_tickets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_changes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "original_scope": { "type": "string" },
          "new_scope": { "type": "string" },
          "reason": { "type": "string" },
          "decided_by": { "type": "string" },
          "impact": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "referenced_at": { "type": ["string", "null"] },
          "task_doc_reference": { "type": ["string", "null"] },
          "confidence": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"]
          },
          "confidence_reason": { "type": "string" }
        }
      }
    },
    "your_tasks": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "user_name": { "type": "string" },
        "owned_tickets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tasks_todo": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "description": { "type": "string" },
              "source": { "type": "string" },
              "priority": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "blocked_by": { "type": ["string", "null"] },
              "referenced_at": { "type": ["string", "null"] }
            }
          }
        },
        "tasks_waiting_on_others": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "description": { "type": "string" },
              "waiting_on": { "type": "string" },
              "source": { "type": "string" },
              "referenced_at": { "type": ["string", "null"] }
            }
          }
        },
        "decisions_needed": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "description": { "type": "string" },
              "from_whom": { "type": "string" },
              "source": { "type": "string" },
              "referenced_at": { "type": ["string", "null"] }
            }
          }
        },
        "completed_in_call": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary": { "type": "string" }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "type", "description"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "database_prerequisite", "pending_decision", "dba_work", "external_dependency",
              "testing", "deployment", "legal_review", "budget_approval", "vendor_dependency",
              "regulatory", "access_permission", "resource_constraint", "backend_work"
            ]
          },
          "description": { "type": "string" },
          "owner": { "type": "string" },
          "blocks": {
            "type": "array",
            "items": { "type": "string" }
          },
          "environments": {
            "type": "array",
            "items": { "type": "string" }
          },
          "checklist_match": { "type": ["string", "null"] },
          "status": {
            "type": "string",
            "enum": ["open", "resolved", "partially_resolved"]
          },
          "referenced_at": { "type": ["string", "null"] },
          "confidence": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"]
          },
          "confidence_reason": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
